{
  "name": "hypequery-monorepo",
  "private": true,
  "workspaces": [
    "packages/cli",
    "packages/clickhouse",
    "packages/create-app",
    "packages/react",
    "packages/serve",
    "packages/tsconfig",
    "examples/*",
    "website"
  ],
  "license": "Apache-2.0",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "test": "turbo run test --filter='@hypequery/*'",
    "types": "turbo run types",
    "test:integration": "cd packages/clickhouse && npm run test:integration",
    "lint": "turbo run lint",
    "start": "turbo run dev",
    "docs:api": "cd packages/clickhouse && npm run docs:api",
    "docs:mdx": "cd packages/clickhouse && npm run docs:mdx",
    "fix:mdx": "node packages/clickhouse/scripts/fix-mdx-frontmatter.js",
    "dev:example": "npm run build --workspace=@hypequery/clickhouse && npm run dev --workspace=next-dashboard",
    "smoke:cli": "bash scripts/smoke-cli.sh",
    "smoke:next-starter": "bash scripts/smoke-next-starter.sh",
    "smoke:next-dashboard": "bash scripts/smoke-next-dashboard.sh",
    "smoke:vite-starter": "bash scripts/smoke-vite-starter.sh",
    "smoke:node-embedded": "bash scripts/smoke-node-embedded.sh",
    "smoke:serve-adapters": "bash scripts/smoke-serve-adapters.sh",
    "smoke:examples": "pnpm smoke:cli && pnpm smoke:next-starter && pnpm smoke:vite-starter && pnpm smoke:node-embedded && pnpm smoke:next-dashboard && pnpm smoke:serve-adapters",
    "changeset": "changeset",
    "release:version": "changeset version",
    "release:publish": "changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.8",
    "@type-challenges/utils": "^0.1.1",
    "@typescript-eslint/eslint-plugin": "^5.0.0",
    "@typescript-eslint/parser": "^5.0.0",
    "eslint": "^8.0.0",
    "turbo": "^1.10.0",
    "typescript": "^4.9.0"
  },
  "pnpm": {
    "overrides": {
      "ajv": "^6.14.0",
      "brace-expansion": "^2.0.3",
      "esbuild": "^0.25.0",
      "flatted": "^3.4.2",
      "glob": "^10.5.0",
      "lodash": "^4.18.0",
      "markdown-it": "^14.1.1",
      "minimatch": "^10.2.3",
      "picomatch": "^4.0.4",
      "rollup": "^4.59.0",
      "vite": "^6.4.2",
      "yaml": "^2.8.3"
    }
  }
}
