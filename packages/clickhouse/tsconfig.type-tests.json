{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": true,
    "skipLibCheck": true,
    "rootDir": "./",
    "outDir": "./.type-tests",
    "composite": false
  },
  "include": [
    "type-tests/**/*.ts",
    "src/**/*.ts"
  ],
  "exclude": [
    "src/**/*.test.ts",
    "src/core/tests/**/*",
    "src/dataset/*.test.ts"
  ]
}
