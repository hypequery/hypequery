{
  "name": "@hypequery/datasets",
  "version": "0.2.0",
  "description": "Semantic layer for defining datasets, metrics, and semantic queries",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    },
    "./internal": {
      "types": "./dist/internal.d.ts",
      "import": "./dist/internal.js",
      "require": "./dist/internal.js"
    }
  },
  "typesVersions": {
    "*": {
      "internal": [
        "./dist/internal.d.ts"
      ]
    }
  },
  "license": "Apache-2.0",
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "dev": "tsc --watch",
    "test": "npm run test:types && npm run test:unit",
    "test:unit": "vitest run",
    "test:integration": "vitest run",
    "test:types": "tsc --project tsconfig.type-tests.json",
    "test:watch": "vitest watch",
    "test:coverage": "vitest run --coverage"
  },
  "files": [
    "dist"
  ],
  "dependencies": {
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/node": "^18.19.80",
    "typescript": "^5.7.3",
    "@vitest/coverage-v8": "^2.1.6",
    "vitest": "^2.1.6"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/hypequery/hypequery.git"
  },
  "homepage": "https://hypequery.com",
  "bugs": {
    "url": "https://github.com/hypequery/hypequery/issues"
  },
  "publishConfig": {
    "access": "public"
  }
}
