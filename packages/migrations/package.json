{
  "name": "@hypequery/migrations",
  "version": "0.0.0",
  "description": "Schema migrations for ClickHouse with Hypequery",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    }
  },
  "license": "Apache-2.0",
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "dev": "tsc --watch",
    "test": "npm run test:types && npm run test:unit",
    "test:unit": "vitest run --config vitest.config.ts",
    "test:types": "tsc --project tsconfig.type-tests.json",
    "test:watch": "vitest watch --config vitest.config.ts",
    "test:coverage": "vitest run --coverage --config vitest.config.ts",
    "lint": "eslint --ext .ts \"src/**/*.ts\""
  },
  "files": [
    "dist",
    "README.md"
  ],
  "dependencies": {},
  "devDependencies": {
    "@types/node": "^18.19.80",
    "typescript": "^5.7.3",
    "@vitest/coverage-v8": "^2.1.6",
    "vitest": "^2.1.6"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/hypequery/hypequery.git"
  },
  "homepage": "https://hypequery.com",
  "bugs": {
    "url": "https://github.com/hypequery/hypequery/issues"
  },
  "publishConfig": {
    "access": "public"
  }
}
