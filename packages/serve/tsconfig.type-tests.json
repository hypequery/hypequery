{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": true,
    "rootDir": ".",
    "outDir": "./.type-tests",
    "composite": false
  },
  "include": [
    "src/**/*.ts",
    "type-tests/**/*.ts"
  ],
  "exclude": [
    "src/**/*.test.ts",
    "src/**/*.integration.spec.ts"
  ]
}
